{
  "version": "2026-04-11",
  "description": "全局违禁词列表，适用于所有链路的后置规则合规检查",
  "forbidden_words": [
    {
      "word": "保证",
      "category": "承诺类",
      "note": "不得对客户做任何保证性承诺",
      "exclude_patterns": ["保证金", "担保保证"]
    },
    {
      "word": "承诺减免",
      "category": "承诺类",
      "note": "减免方案需以实际审批为准"
    },
    {
      "word": "一定可以",
      "category": "承诺类",
      "note": "不得做确定性承诺"
    },
    {
      "word": "绝对",
      "category": "承诺类",
      "note": "禁止使用绝对化用语"
    },
    {
      "word": "肯定没问题",
      "category": "承诺类",
      "note": "不得做确定性承诺"
    },
    {
      "word": "百分之百",
      "category": "承诺类",
      "note": "禁止使用绝对化用语"
    },
    {
      "word": "我帮你操作",
      "category": "超权类",
      "note": "坐席不得暗示可直接操作客户账户，应说'建议您'",
      "exclude_patterns": ["我帮你查询", "我帮你核实"]
    },
    {
      "word": "我给你免除",
      "category": "超权类",
      "note": "坐席无权直接免除费用"
    },
    {
      "word": "我直接给你",
      "category": "超权类",
      "note": "坐席不得暗示可直接操作"
    },
    {
      "word": "不合法",
      "category": "定性类",
      "note": "坐席不得对公司业务做合法性定性",
      "exclude_patterns": ["如果您认为不合法"]
    },
    {
      "word": "高利贷",
      "category": "定性类",
      "note": "坐席不得使用此词描述公司产品"
    },
    {
      "word": "骗",
      "category": "定性类",
      "note": "坐席不得使用此词描述公司行为",
      "exclude_patterns": ["防骗", "诈骗"]
    },
    {
      "word": "投诉无门",
      "category": "服务态度类",
      "note": "不得暗示客户无法投诉"
    },
    {
      "word": "你自己的问题",
      "category": "服务态度类",
      "note": "不得将责任推给客户"
    },
    {
      "word": "没办法",
      "category": "服务态度类",
      "note": "应使用'目前暂时无法'等委婉表达"
    },
    {
      "word": "管不了",
      "category": "服务态度类",
      "note": "应使用'目前暂时无法处理'等委婉表达"
    }
  ],
  "pii_patterns": [
    {
      "name": "身份证号完整",
      "regex": "\\d{17}[\\dXx]",
      "note": "输出中不得包含完整身份证号"
    },
    {
      "name": "手机号完整",
      "regex": "1[3-9]\\d{9}",
      "note": "输出中不得包含完整手机号，应使用脱敏格式"
    },
    {
      "name": "银行卡号",
      "regex": "\\d{16,19}",
      "note": "输出中不得包含完整银行卡号"
    }
  ]
}
